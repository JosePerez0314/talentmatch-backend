generator client {
  provider = "prisma-client-js"
}

generator docs {
  provider = "node node_modules/prisma-docs-generator"
  output   = "../docs"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  USER
}

enum EducationLevel {
  NONE
  HIGH_SCHOOL
  BACHELOR
  MASTER
  DOCTORATE
}

enum VacancyStatus {
  ACTIVE
  PAUSED
  CLOSED
}

/// Represents an HR Administrator or Recruiter using the TalentMatch AI platform.
model User {
  id          Int          @id @default(autoincrement())
  email       String       @unique
  password    String
  role        UserRole     @default(USER)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  departments Department[]
  positions   Position[]
  vacancies   Vacancy[]
  candidates  Candidate[]
}

/// Groups positions under a business unit. Parent container of Position.
model Department {
  id        Int        @id @default(autoincrement())
  title     String
  userId    Int
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  user      User       @relation(fields: [userId], references: [id])
  positions Position[]

  @@index([userId])
}

/// Defines the job requirements baseline used by the AI to evaluate candidates.
model Position {
  id                      Int            @id @default(autoincrement())
  /// The official title of the job opening.
  role                    String
  yearsOfExperience       Int
  description             String         @db.Text
  /// Required hard skills — array of strings stored as JSON.
  technicalSkills         Json
  /// Nice-to-have skills — array of strings stored as JSON.
  optionalTechnicalSkills Json
  /// Interpersonal skills — array of strings stored as JSON.
  softSkills              Json
  /// Required languages — array of strings stored as JSON.
  languages               Json
  /// Minimum education level required.
  educationLevel          EducationLevel
  /// Required field of study (e.g. "Computer Science").
  educationArea           String
  /// Cloudinary URL of the uploaded job description PDF used for AI autocompletion.
  positionPdfUrl          String?
  departmentId            Int
  userId                  Int
  createdAt               DateTime       @default(now())
  updatedAt               DateTime       @updatedAt
  department              Department     @relation(fields: [departmentId], references: [id])
  user                    User           @relation(fields: [userId], references: [id])
  vacancies               Vacancy[]

  @@index([userId, createdAt])
  @@index([departmentId])
}

/// An active job posting linked to a Position. Candidates are uploaded directly here.
model Vacancy {
  id             Int           @id @default(autoincrement())
  title          String
  availableSlots Int
  startDate      DateTime
  endDate        DateTime
  status         VacancyStatus @default(ACTIVE)
  positionId     Int
  departmentId   Int
  userId         Int
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  position       Position      @relation(fields: [positionId], references: [id])
  user           User          @relation(fields: [userId], references: [id])
  candidates     Candidate[]
  matchResults   MatchResult[]

  @@index([userId, status])
  @@index([status])
  @@index([positionId])
  @@index([departmentId])
}

/// Candidate parsed from a CV PDF uploaded directly to a Vacancy.
model Candidate {
  id                      Int            @id @default(autoincrement())
  fullName                String
  email                   String
  description             String         @db.Text
  educationLevel          EducationLevel
  educationArea           String
  /// Cloudinary URL of the original CV PDF.
  fileUrl                 String?
  /// Spoken languages extracted from the CV — array of strings stored as JSON.
  languages               Json
  optionalTechnicalSkills Json
  softSkills              Json
  technicalSkills         Json
  role                    String
  yearsOfExperience       Int
  /// SHA-256 hash of parsed CV text. Prevents duplicate OpenAI API calls.
  hash                    String         @unique
  /// Raw JSON payload returned by the AI for auditing.
  rawApiPayload           Json
  vacancyId               Int
  userId                  Int
  createdAt               DateTime       @default(now())
  updatedAt               DateTime       @updatedAt
  vacancy                 Vacancy        @relation(fields: [vacancyId], references: [id])
  user                    User           @relation(fields: [userId], references: [id])
  matchResults            MatchResult[]

  @@index([userId, createdAt])
  @@index([vacancyId])
}

/// AI evaluation score connecting a Candidate to a Vacancy.
model MatchResult {
  id                  Int       @id @default(autoincrement())
  matchScore          Int
  educationScore      Int
  experienceScore     Int
  hardSkillsScore     Int
  languagesScore      Int
  roleScore           Int
  softSkillsScore     Int
  /// Cached snapshot of candidate data at evaluation time for auditability.
  normalizedCandidate Json
  redFlags            String?   @db.Text
  summary             String    @db.Text
  candidateId         Int
  vacancyId           Int
  createdAt           DateTime  @default(now())
  candidate           Candidate @relation(fields: [candidateId], references: [id])
  vacancy             Vacancy   @relation(fields: [vacancyId], references: [id])

  @@unique([candidateId, vacancyId])
  @@index([candidateId])
  @@index([vacancyId])
}
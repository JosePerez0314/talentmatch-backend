generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id       Int    @id @default(autoincrement())
  email    String @unique
  password String

  // Applying the relationship with Position and Candidate models
  position Position[]
  candidates Candidate[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Position {
  id Int @id @default(autoincrement())
  role String
  yearsOfExperience Int
  technicalSkills String
  optionalTechnicalSkills String
  softSkills String
  description String
  education String
  languages String

  // Relationship between both tables
  userId Int 
  user User @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  vacancies Vacancy[]
  candidates Candidate[]
}

model Candidate {
  id Int @id @default(autoincrement())

  // Data that the user should see
  fullName String
  email String @unique
  fileUrl String @unique

  // Data to compare
  role String
  yearsOfExperience Int
  technicalSkills String
  optionalTechnicalSkills String
  softSkills String
  description String
  education String
  languages String

  aiAnalysis Json // Ai Analysis to complete the columns

  userId Int
  user User @relation(fields: [userId], references: [id]) // Relationship between the both tables

  positionId Int
  position Position @relation(fields: [positionId], references: [id])

  matchResults MatchResult[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Vacancy {
  id Int @id @default(autoincrement())
  title String
  openDate DateTime
  closeDate DateTime

  positionId Int
  position Position @relation(fields: [positionId], references: [id])

  matchResults MatchResult[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MatchResult {
  id Int @id @default(autoincrement())
  matchScore Int

  candidateId Int
  candidate   Candidate @relation(fields: [candidateId], references: [id])

  vacancyId   Int
  vacancy     Vacancy @relation(fields: [vacancyId], references: [id])

  @@unique([candidateId, vacancyId])
  createdAt DateTime @default(now())
}
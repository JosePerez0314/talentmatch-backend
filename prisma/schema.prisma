generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

model User {
  id       Int    @id @default(autoincrement())
  email    String @unique
  password String
}

model SmartSearch {
  id Int @id @default(autoincrement())
  rol String
  yearsExperience Int
  hardSkills String
  description String
  candidates Candidate[]
}

model Candidate {
  id Int @id @default(autoincrement())
  fullName String
  email String
  fileName String
  matchCore Int
  createAT DateTime @default(now())

  searchID Int
  search SmartSearch @relation(fields: [searchID], references: [id])
}